# Configuration file for pytest-cov
[run]
branch = True
source = core/
omit =
    */tests/*
    */__pycache__/*
    */venv/*
    */.venv/*
    */migrations/*
    */site-packages/*

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    raise AssertionError
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:
    @abstractmethod

precision = 2
show_missing = True
skip_covered = False

[html]
directory = htmlcov
title = Coverage Report

[xml]
output = coverage.xml
