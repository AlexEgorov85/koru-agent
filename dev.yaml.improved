# config/dev.yaml
# Конфигурация для разработки
profile: dev
debug: true
log_level: DEBUG
log_dir: logs/dev
data_dir: data/dev

# Конфигурация LLM провайдеров
llm_providers:
  default_llm:
    provider_type: llama_cpp
    model_name: qwen-4b
    enabled: true
    fallback_providers: []
    parameters:
      model_path: "./models/qwen3-4b-instruct-f16.gguf"  # Относительный путь
      n_ctx: 2048
      n_gpu_layers: 0
      n_batch: 512
      temperature: 0.2
      max_tokens: 512
      verbose: false
      stop: ["<|endoftext|>", "</s>"]

# Конфигурация баз данных
db_providers:
  default_db:
    provider_type: postgres
    enabled: true
    parameters:
      host: "localhost"
      port: 5432
      database: "agent_dev"
      username: "postgres"
      password: "password"  # Должно быть в секрете на проде
      sslmode: "prefer"
      timeout: 30.0
      pool_size: 5

# Конфигурация навыков
skills:
  planning:
    enabled: true
    parameters: {}
    priority: 1
  book_library:
    enabled: true
    parameters:
      max_books_per_search: 10
    priority: 1

# Конфигурация инструментов
tools:
  SQLTool:
    enabled: true
    parameters: {}
    dependencies: ["default_db"]
  file_tool:
    enabled: true
    parameters: {}
    dependencies: []

# Параметры агента
agent:
  max_steps: 10
  max_retries: 3
  temperature: 0.2
  default_strategy: "react"
  enable_self_reflection: true
  enable_context_window_management: true

# Безопасность
security:
  secrets_path: "core/config/defaults/secrets_dev.yaml"
  token_expiry_minutes: 60

# Дополнительные провайдеры
providers:
  cache:
    enabled: true
    type: "memory"
    ttl: 300
  monitoring:
    enabled: true
    endpoint: "http://localhost:9090"