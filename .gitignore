config/secrets.yml
config/secrets.yaml
config/database.yml
config/database.yaml
*.config
.secrets
*.secrets
secret_token.rb
nul  
data/metrics/default_llm/latest/metrics.json

# Runtime-generated metrics (auto-generated on agent runs)
data/metrics/
