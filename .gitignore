```gitignore
# Python compiled files
*.pyc
__pycache__/

# Logs and session data
data/logs/
*.log

# Environment and dependency directories
.venv/
venv/
.env
.env.local
.env.*

# Editor/IDE files
.vscode/
.idea/
*.swp
*.swo
*.tmp

# Coverage and testing
.coverage
coverage/
htmlcov/

# OS generated files
.DS_Store
Thumbs.db
```