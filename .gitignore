```gitignore
# Python compiled files
*.pyc
__pycache__/

# Logs
data/logs/
*.log

# Environment files
.env
.env.local
*.env.*

# Dependencies and build artifacts
.venv/
venv/
node_modules/
dist/
build/
.mypy_cache/
.pytest_cache/
.coverage
coverage/
htmlcov/

# Editor/IDE files
.vscode/
.idea/
*.swp
*.swo
*.tmp

# System files
.DS_Store
Thumbs.db

# Compressed files
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst
```