```gitignore
# Python cache files
__pycache__/
*.pyc
*.pyo
*.pyd

# Test cache and coverage
.pytest_cache/
.coverage
coverage/
htmlcov/

# Logs
*.log

# Environment files
.env
.env.local
*.env.*

# Temporary files
*.tmp
*.swp
*.swo

# IDE specific
.vscode/
.idea/

# Dependencies and builds
venv/
.venv/
pip-wheel-metadata/
.wheelhouse/
.mypy_cache/
__pypackages__/
```