# PROJECT SPECIFIC
# =============================================================================

# Project-specific ignores
core/events/event_bus_test.py
core/events/event_handlers_test.py

# Exported results
output/
results/
export/

# Agent configuration (local instructions)
AGENTS.md

# Architecture documents (if sensitive)
ARCHITECTURE.md
ARCHITECTURE_DECISIONS.md
ARCHITECTURE_CHECKLIST.md

# Allow DataAnalysisSkill files
!data/manifests/skills/data_analysis/**
!data/contracts/skill/data_analysis/**
!data/prompts/skill/data_analysis/**

# Local configuration (may contain secrets)
config/local/*
