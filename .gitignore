```gitignore
# Python compiled files
__pycache__/
*.pyc
*.pyo
*.pyd

# Virtual environments
venv/
.venv/
env/
.ENV/

# Dependencies
node_modules/
pip-wheel-metadata/
*.egg-info/

# Build and distribution
dist/
build/
*.egg
*.whl
*.tar.gz
*.zip

# Testing
.coverage
htmlcov/
.pytest_cache/
.hypothesis/

# Logs
*.log

# OS generated files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Environment variables
.env
.env.local
*.env.*

# Coverage reports
coverage/
```