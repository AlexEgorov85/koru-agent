```gitignore
# Python compiled files
__pycache__/
*.pyc
*.pyo
*.pyd

# Logs
logs/
*.log

# Session data
data/logs/

# Coverage reports
.coverage
htmlcov/
coverage/

# Virtual environments
venv/
.venv/
env/
.ENV/

# IDE specific
.vscode/
.idea/
*.swp
*.swo

# OS specific
.DS_Store
Thumbs.db

# Testing
.pytest_cache/
.mypy_cache/

# Distribution / packaging
dist/
build/
*.egg-info/

# Environment variables
.env
.env.local
*.env.*

# Temporary files
*.tmp
*.temp
```